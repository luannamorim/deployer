# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME=deployer
APP_VERSION=0.1.0
ENVIRONMENT=development       # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ─────────────────────────────────────────────
# Auth
# Comma-separated list of valid API keys.
# Set REQUIRE_AUTH=false to disable auth (dev only).
# ─────────────────────────────────────────────
API_KEYS=changeme-key-1,changeme-key-2
REQUIRE_AUTH=true

# ─────────────────────────────────────────────
# LLM Provider
# Set llm_provider to "openai" or "anthropic".
# Only the matching API key is required.
# ─────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=gpt-4o-mini
REQUEST_TIMEOUT=60

# ─────────────────────────────────────────────
# Rate Limiting
# Sliding window per API key, backed by Redis.
# ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ─────────────────────────────────────────────
# Response Cache
# Keyed by SHA-256(model + messages + temperature).
# ─────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# ─────────────────────────────────────────────
# Redis
# Used for rate limiting and response cache.
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# Circuit Breaker
# Opens after THRESHOLD consecutive failures.
# Moves to half-open after RECOVERY_SECONDS.
# ─────────────────────────────────────────────
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=30

# ─────────────────────────────────────────────
# CORS
# Comma-separated list of allowed origins.
# Use * for development; restrict in production.
# ─────────────────────────────────────────────
CORS_ORIGINS=*
