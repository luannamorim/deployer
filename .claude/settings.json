{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Bash(rm -rf *)",
            "Bash(sudo *)",
            "Bash(git push *)",
            "Bash(curl *)",
            "Bash(wget *)"
        ]
    }
}
